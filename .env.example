# =============================================================================
# Victus AI — Root environment template
# Copy to `.env` and adjust for local development.
# Production secrets MUST be sourced from a secrets manager (AWS SM, GCP SM,
# HashiCorp Vault) — never commit a populated .env to version control.
# =============================================================================

# ---------- Postgres (docker-compose) ----------
POSTGRES_USER=victus
POSTGRES_PASSWORD=victus_dev_only_change_me
POSTGRES_DB=victus
POSTGRES_PORT=5432

# ---------- FastAPI ----------
# Async DSN consumed by SQLAlchemy/asyncpg
DATABASE_URL=postgresql+asyncpg://victus:victus_dev_only_change_me@localhost:5432/victus
# Sync DSN consumed by Alembic
ALEMBIC_DATABASE_URL=postgresql+psycopg://victus:victus_dev_only_change_me@localhost:5432/victus

API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development
API_LOG_LEVEL=INFO

# 256-bit hex string; generate with: openssl rand -hex 32
JWT_SECRET_KEY=replace_me_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# Comma-separated origins permitted by CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Inter-service shared secret (Next.js -> FastAPI privileged endpoints).
# Generate with: openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=replace_me_with_openssl_rand_hex_32

# Pathway A — Evidential Deep Learning checkpoint.
# Path to a state-dict produced by `python -m victus_api.training.cli`.
# When unset (or pointing at a missing file), the API silently falls back to
# the rule-based predictor and emits a structured warning log.
# Shipped v1 demo: trained DANN-augmented Dirichlet head with CHW domain invariance.
VICTUS_TRIAGE_MODEL_PATH=apps/api/models/triage_edl_v1_demo.pt

# ---------- Next.js ----------
# Public base used by the browser
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Server-side base used by Next.js server components / route handlers
INTERNAL_API_BASE_URL=http://localhost:8000

# Auth.js v5
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace_me_with_openssl_rand_base64_32
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Kiosk terminal identity (this deployment). Held server-side by Next.js and
# forwarded to FastAPI as X-Kiosk-Id / X-Kiosk-Token; never exposed to the
# browser. KIOSK_ID:KIOSK_DEVICE_TOKEN must match one pair in the API's
# KIOSK_DEVICE_TOKENS. Leave unset to disable the kiosk rail on this instance.
KIOSK_ID=
KIOSK_DEVICE_TOKEN=

# ---------- Marketing site (apps/marketing) ----------
# Where the "Sign In" CTA points. Production: https://app.victusdata.com
# NOTE: build-time inlined — must be set when running `pnpm build:cpanel`.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Lead forwarding (runtime — set these in the cPanel Node.js app environment).
# At least one channel (SMTP or webhook) must be configured in production;
# with neither set, leads are only written to the server log.
#
# SMTP — any mailbox created in cPanel (Email Accounts) works:
#   host = mail.victusdata.com, port 465 (SSL) or 587 (SMTP_SECURE=false)
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
LEAD_NOTIFY_TO=
LEAD_NOTIFY_FROM=
# Optional CRM webhook (HubSpot/Zoho inbound webhook, Zapier/Make, etc.)
CRM_WEBHOOK_URL=
CRM_WEBHOOK_TOKEN=

# ---------- Mobile Clinic Gateway (kiosk rail) ----------
# AES-256 key for kiosk clinical-result payloads — 64 hex chars (openssl rand
# -hex 32) or base64 decoding to 32 bytes. Source from the secrets manager;
# the API refuses to boot in production while this is the dev placeholder.
KIOSK_ENCRYPTION_KEY=
# Version label stamped on every ciphertext (lets a future key rotation still
# decrypt older rows). Bump when you rotate KIOSK_ENCRYPTION_KEY.
KIOSK_KEY_ID=kiosk-dev-1
# Server-side hard ceiling on an unfinished kiosk session (seconds).
KIOSK_SESSION_TTL_SECONDS=900
# Secure-result token lifetime — spec mandates 24h (86400s).
KIOSK_RESULT_TOKEN_TTL_SECONDS=86400
# Wrong-OTP attempts before a result token is permanently locked.
KIOSK_OTP_MAX_ATTEMPTS=5
# Per-terminal device tokens: "kioskId:token" pairs, comma-separated. The kiosk
# sends X-Kiosk-Id + X-Kiosk-Token; both must match. Fail-closed in production.
KIOSK_DEVICE_TOKENS=
# E.164 number (digits only) the kiosk QR deep-links into WhatsApp (wa.me/<n>).
KIOSK_WHATSAPP_NUMBER=
