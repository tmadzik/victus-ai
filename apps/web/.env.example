# Public — exposed to the browser. Keep secrets OUT of NEXT_PUBLIC_* vars.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Server-only — used by Next.js server components and route handlers.
INTERNAL_API_BASE_URL=http://localhost:8000
INTERNAL_SERVICE_TOKEN=replace_me_matching_apps_api_env

# Auth.js v5 — generate with: openssl rand -base64 32
AUTH_SECRET=replace_me_with_openssl_rand_base64_32
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true
