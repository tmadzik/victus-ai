# Keep the API build context small and deterministic.
.venv
**/__pycache__
*.pyc
.pytest_cache
.ruff_cache
.mypy_cache
htmlcov
.coverage
*.log
tests
# The trained checkpoints are only ~100 KB in total, so they ship in every image.
# They are inert unless the image was built WITH_TORCH=1 *and*
# VICTUS_TRIAGE_MODEL_PATH points at one — otherwise the rule-based backend runs.
