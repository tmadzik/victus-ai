# ============================================================================
# Victus AI — production environment (Hostinger VPS / Docker Compose)
#
#   cp infra/.env.production.example infra/.env.production
#   then fill in the secrets below and adjust the domains.
#
# NEVER commit the filled-in .env.production. Generate every secret fresh.
# ============================================================================

# --- Domains ----------------------------------------------------------------
# The four hostnames. Point all of them at the VPS IP in your DNS (A records).
ROOT_DOMAIN=victusdata.com
WWW_DOMAIN=www.victusdata.com
APP_DOMAIN=app.victusdata.com
API_DOMAIN=api.victusdata.com

# Public URLs (https) derived from the domains above — used for CORS, auth
# callbacks, and baked into the browser bundle at build time.
PUBLIC_WWW_URL=https://www.victusdata.com
PUBLIC_APP_URL=https://app.victusdata.com
PUBLIC_API_URL=https://api.victusdata.com

# Email for Let's Encrypt certificate registration / expiry notices.
ACME_EMAIL=you@example.com

# --- Database ---------------------------------------------------------------
POSTGRES_USER=victus
POSTGRES_DB=victus
# Generate: openssl rand -hex 24
POSTGRES_PASSWORD=CHANGE_ME_openssl_rand_hex_24

# --- Application secrets (generate every one; never reuse the examples) ------
# openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_openssl_rand_hex_32
# openssl rand -hex 32   (must be identical for api + web + worker)
INTERNAL_SERVICE_TOKEN=CHANGE_ME_openssl_rand_hex_32
# openssl rand -hex 32   (NEVER rotate after launch — it salts pseudonymous IDs)
PSEUDO_SALT=CHANGE_ME_openssl_rand_hex_32
# openssl rand -hex 32   (AES-256 key for the kiosk result envelope)
KIOSK_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_hex_32
# openssl rand -base64 48   (web session cookie signing)
AUTH_SECRET=CHANGE_ME_openssl_rand_base64_48

# Site label stamped on records created by this instance (e.g. DEMO, ZW, NG).
SITE_CODE=DEMO

# --- Marketing "request a pilot" email (OPTIONAL) ---------------------------
# Leave blank to disable email; the form still records the lead.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
LEAD_NOTIFY_TO=
LEAD_NOTIFY_FROM=

# --- WhatsApp worker (OPTIONAL, off by default) -----------------------------
# Only needed if you run `--profile whatsapp`. From Meta after verification.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
